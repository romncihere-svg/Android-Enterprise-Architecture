<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EstranoStarter" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorSecondary">@color/neon_purple</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowAnimationStyle">@style/WindowFadeAnimation</item>

        <!-- System Bars — fully transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Material overrides -->
        <item name="materialButtonStyle">@style/EstranoButtonStyle</item>
        <item name="chipStyle">@style/EstranoChipStyle</item>
        <item name="bottomNavigationStyle">@style/EstranoBottomNavStyle</item>
    </style>

    <!-- Smooth fade between activities -->
    <style name="WindowFadeAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out</item>
    </style>
</resources>