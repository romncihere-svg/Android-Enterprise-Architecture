<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Typography ──────────────────────────────────── -->
    <style name="TextHeroTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextDisplayLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextBodyPrimary">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextBodyStrong">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextBadge">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.2</item>
    </style>

    <!-- ── Button ──────────────────────────────────────── -->
    <style name="EstranoButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/background</item>
        <item name="backgroundTint">@color/neon_cyan</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- ── Chip ────────────────────────────────────────── -->
    <style name="EstranoChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/white</item>
        <item name="chipBackgroundColor">#1A00E5FF</item>
        <item name="chipStrokeColor">@color/neon_cyan</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">10dp</item>
        <item name="checkedIconTint">@color/neon_cyan</item>
    </style>

    <!-- ── Bottom Navigation ───────────────────────────── -->
    <style name="EstranoBottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/neon_cyan</item>
        <item name="itemTextColor">@color/text_secondary</item>
        <item name="itemActiveIndicatorColor">#1A00E5FF</item>
        <item name="android:background">@color/surface</item>
    </style>

</resources>